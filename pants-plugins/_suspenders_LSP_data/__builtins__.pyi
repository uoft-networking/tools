    name: str,
    tags: Iterable[str] | None = None,
    description: str | None = None,
    platform: Literal["linux_arm64", "linux_x86_64", "macos_arm64", "macos_x86_64"] | None = "linux_x86_64",
    extra_platform_properties: Iterable[str] | None = (),
